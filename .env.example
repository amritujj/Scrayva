# Scrayva Worker — local development environment variables
# Copy this file to .env and fill in your actual values.
# This file is loaded automatically by python-dotenv when you run the worker locally.
# On Render (production), set these in the dashboard instead — do NOT commit .env to git.

GOOGLE_API_KEY=your_google_api_key_here
# Gemini Model Override (Optional)
# GEMINI_MODEL="gemini-2.0-flash"

# Razorpay Keys (For Payments)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- AI Voice API Keys ---
# Get your Sarvam AI keys from https://sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# Optional: comma-separated list of frontend origins allowed to call the worker.
# Defaults to http://localhost:3000,http://127.0.0.1:3000 if not set.
# ALLOWED_ORIGINS=https://yourdomain.vercel.app
